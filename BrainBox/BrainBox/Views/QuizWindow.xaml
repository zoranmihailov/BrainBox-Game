<Window x:Class="BrainBox.Views.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Прашања" Height="550" Width="840"
        WindowStartupLocation="CenterScreen"
        Background="#468432">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBlock x:Name="txtQuestionNum" Foreground="White" FontSize="14"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtCategory" Foreground="White" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtTimer" Foreground="#FFA02E" FontSize="20"
                       FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <TextBlock x:Name="txtQuestion" Grid.Row="1" Foreground="#FFEF91" FontSize="18"
                   FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center"/>

        <UniformGrid Grid.Row="2" Rows="2" Columns="2" Margin="0,5,0,5">
            <Button x:Name="btnA" Height="70" Margin="8" FontSize="16"
            Background="#FFA02E" Click="AnswerClick"/>
            <Button x:Name="btnB" Height="70" Margin="8" FontSize="16"
            Background="#FFA02E" Click="AnswerClick"/>
            <Button x:Name="btnC" Height="70" Margin="8" FontSize="16"
            Background="#FFA02E" Click="AnswerClick"/>
            <Button x:Name="btnD" Height="70" Margin="8" FontSize="16"
            Background="#FFA02E" Click="AnswerClick"/>
        </UniformGrid>

        <Button Grid.Row="3" Content="Прескокни" Height="40"
                Background="#FFA02E" FontSize="14"
                HorizontalAlignment="Center" Width="200"
                Click="SkipClick"/>

        <TextBlock x:Name="txtScore" Grid.Row="4" Foreground="#FFEF91" FontSize="16"
                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
    </Grid>
</Window>
