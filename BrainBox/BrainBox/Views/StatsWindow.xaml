<Window x:Class="BrainBox.Views.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика" Height="550" Width="840"
        WindowStartupLocation="CenterScreen"
        Background="#468432">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="СТАТИСТИКА" Foreground="#ffef91" FontSize="28"
                   FontWeight="Bold" Grid.Row="0" Margin="0,0,0,5"/>

        <TextBlock x:Name="txtPlayerName" Foreground="#9ad872" FontSize="16"
                   Grid.Row="1" Margin="0,0,0,20"/>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Игра" Grid.Row="0" Grid.Column="0"
                       Foreground="#ffa02e" FontSize="15" FontWeight="Bold" Margin="5"/>
            <TextBlock Text="Макс" Grid.Row="0" Grid.Column="1"
                       Foreground="#ffa02e" FontSize="15" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="5"/>
            <TextBlock Text="Највисок" Grid.Row="0" Grid.Column="2"
                       Foreground="#ffa02e" FontSize="15" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="5"/>
            <TextBlock Text="Просек" Grid.Row="0" Grid.Column="3"
                       Foreground="#ffa02e" FontSize="15" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="5"/>
            <TextBlock Text="Партии" Grid.Row="0" Grid.Column="4"
                       Foreground="#ffa02e" FontSize="15" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="5"/>


            <TextBlock Text="Wordle" Grid.Row="1" Grid.Column="0"
                       Foreground="#ffef91" FontSize="15" Margin="5" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtWordleMax" Grid.Row="1" Grid.Column="1"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>
            <TextBlock x:Name="txtWordleHigh" Grid.Row="1" Grid.Column="2"
                       Foreground="#ffef91" FontSize="15" HorizontalAlignment="Center" Margin="5" FontWeight="Bold"/>
            <TextBlock x:Name="txtWordleAvg" Grid.Row="1" Grid.Column="3"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>
            <TextBlock x:Name="txtWordleGames" Grid.Row="1" Grid.Column="4"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>


            <TextBlock Text="Математика" Grid.Row="2" Grid.Column="0"
                       Foreground="#ffef91" FontSize="15" Margin="5" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtMathMax" Grid.Row="2" Grid.Column="1"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>
            <TextBlock x:Name="txtMathHigh" Grid.Row="2" Grid.Column="2"
                       Foreground="#ffef91" FontSize="15" HorizontalAlignment="Center" Margin="5" FontWeight="Bold"/>
            <TextBlock x:Name="txtMathAvg" Grid.Row="2" Grid.Column="3"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>
            <TextBlock x:Name="txtMathGames" Grid.Row="2" Grid.Column="4"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>


            <TextBlock Text="Комбинација" Grid.Row="3" Grid.Column="0"
                       Foreground="#ffef91" FontSize="15" Margin="5" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtCombMax" Grid.Row="3" Grid.Column="1"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>
            <TextBlock x:Name="txtCombHigh" Grid.Row="3" Grid.Column="2"
                       Foreground="#ffef91" FontSize="15" HorizontalAlignment="Center" Margin="5" FontWeight="Bold"/>
            <TextBlock x:Name="txtCombAvg" Grid.Row="3" Grid.Column="3"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>
            <TextBlock x:Name="txtCombGames" Grid.Row="3" Grid.Column="4"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>


            <TextBlock Text="Прашања" Grid.Row="4" Grid.Column="0"
                       Foreground="#ffef91" FontSize="15" Margin="5" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtQuizMax" Grid.Row="4" Grid.Column="1"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>
            <TextBlock x:Name="txtQuizHigh" Grid.Row="4" Grid.Column="2"
                       Foreground="#ffef91" FontSize="15" HorizontalAlignment="Center" Margin="5" FontWeight="Bold"/>
            <TextBlock x:Name="txtQuizAvg" Grid.Row="4" Grid.Column="3"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>
            <TextBlock x:Name="txtQuizGames" Grid.Row="4" Grid.Column="4"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>


            <TextBlock Text="Асоцијација" Grid.Row="5" Grid.Column="0"
                       Foreground="#ffef91" FontSize="15" Margin="5" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtAssocMax" Grid.Row="5" Grid.Column="1"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>
            <TextBlock x:Name="txtAssocHigh" Grid.Row="5" Grid.Column="2"
                       Foreground="#ffef91" FontSize="15" HorizontalAlignment="Center" Margin="5" FontWeight="Bold"/>
            <TextBlock x:Name="txtAssocAvg" Grid.Row="5" Grid.Column="3"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>
            <TextBlock x:Name="txtAssocGames" Grid.Row="5" Grid.Column="4"
                       Foreground="#9ad872" FontSize="15" HorizontalAlignment="Center" Margin="5"/>
        </Grid>

        <Border Grid.Row="3" Background="#9ad872" CornerRadius="8" Padding="15" Margin="0,20,0,0">
            <Grid>
                <TextBlock Text="ВКУПЕН РЕЗУЛТАТ:" Foreground="#468432"
                           FontSize="16" FontWeight="Bold" HorizontalAlignment="Left"/>
                <TextBlock x:Name="txtTotal" Foreground="#ffa02e" FontSize="20"
                           FontWeight="Bold" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>