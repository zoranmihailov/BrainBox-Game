<Window x:Class="BrainBox.Views.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BrainBox" Height="500" Width="840"
        WindowStartupLocation="CenterScreen"
        Background="#468432">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="BrainBox" FontSize="42" Foreground="#FFEF91"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock x:Name="txtPlayerName" FontSize="16" Foreground="White"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>
            <Button Content="Start" Height="50" Margin="0,5" FontSize="18"
                    Background="#9AD872" Click="StartGame"/>
            <Button Content="Статистика" Height="45" Margin="0,10,0,0" FontSize="14"
                    Background="#FFA02E" Click="OpenStats"/>
        </StackPanel>
    </Grid>
</Window>