<Window x:Class="BrainBox.Views.AssociationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Асоцијација" Height="600" Width="840"
        WindowStartupLocation="CenterScreen"
        Background="#468432">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Асоцијација" Foreground="#FFEF91" FontSize="28" FontWeight="Bold" HorizontalAlignment="Left"/>
            <TextBlock x:Name="txtTimer" Foreground="#FFA02E" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right"/>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4" x:Name="columnsGrid" Margin="0,0,0,10"/>

        <UniformGrid Grid.Row="2" Columns="4" x:Name="solutionsGrid" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Финален одговор:" Foreground="White" FontSize="16" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtFinalAnswer" FontSize="18" Height="45" Padding="10,5" Grid.Column="0"/>
                <Button Content="Потврди" Height="45" Width="100" Background="#9AD872" FontSize="14"
                        Margin="10,0,0,0" Grid.Column="1" Click="ConfirmFinal"/>
            </Grid>
        </StackPanel>

        <TextBlock x:Name="txtScore" Grid.Row="4" Foreground="#9AD872" FontSize="16" HorizontalAlignment="Center"/>
    </Grid>
</Window>
