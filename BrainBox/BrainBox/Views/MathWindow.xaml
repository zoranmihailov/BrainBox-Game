<Window x:Class="BrainBox.Views.MathWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Математика" Height="600" Width="840"
        WindowStartupLocation="CenterScreen"
        Background="#468432">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Математика" Foreground="#FFEF91" FontSize="28"
                       FontWeight="Bold" HorizontalAlignment="Left"/>
            <TextBlock x:Name="txtTimer" Foreground="#FFA02E" FontSize="24"
                       FontWeight="Bold" HorizontalAlignment="Right"/>
        </Grid>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,15">
            <TextBlock Text="Таргет број:" Foreground="White" FontSize="16"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="txtTarget" Foreground="#FFEF91" FontSize="48"
                       FontWeight="Bold" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Дадени броеви:" Foreground="White" FontSize="16"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <StackPanel x:Name="numbersPanel" Orientation="Horizontal"
                        HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Дозволени оператори:    +    -    *    /    ( )"
                       Foreground="White" FontSize="15"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,15">
            <TextBlock Text="Внеси математички израз:" Foreground="White"
                       FontSize="16" Margin="0,0,0,8"/>
            <TextBox x:Name="txtExpression" FontSize="22" Height="50"
                     Padding="10,5"/>
        </StackPanel>

        <Button Grid.Row="5" Content="Потврди (Enter)" Height="45"
                Background="#9AD872" FontSize="16"
                Click="ConfirmAnswer"/>

        <TextBlock x:Name="txtMessage" Grid.Row="6" Foreground="#FFA02E"
                   FontSize="16" HorizontalAlignment="Center"
                   Margin="0,10,0,0" TextWrapping="Wrap"/>
    </Grid>
</Window>
