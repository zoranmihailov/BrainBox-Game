<Window x:Class="BrainBox.Views.CombinationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Комбинација" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#468432"
        KeyDown="Window_KeyDown">
	<Grid Margin="20">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="280"/>
		</Grid.ColumnDefinitions>

		<StackPanel Grid.Column="0">
			<TextBlock Foreground="White" FontSize="14" Margin="0,0,0,5"
                       Text="1-★   2-♥   3-♠   4-♦   5-♣   6-●"/>
			<TextBlock Foreground="White" FontSize="14" Margin="0,0,0,15"
                       Text="Enter-Потврди   Backspace-Избриши последен   Delete-Избриши сè"/>

			<StackPanel x:Name="attemptsPanel" VerticalAlignment="Top"/>
		</StackPanel>

		<StackPanel Grid.Column="1" Margin="20,0,0,0">
			<TextBlock Text="Комбинација" Foreground="#FFEF91" FontSize="20"
                       FontWeight="Bold" Margin="0,0,0,10"/>
			<TextBlock x:Name="txtTimer" Foreground="#FFA02E" FontSize="24"
                       FontWeight="Bold" Margin="0,0,0,5"/>
			<TextBlock x:Name="txtAttempts" Foreground="White" FontSize="14"
                       Margin="0,0,0,20"/>

			<TextBlock Text="Избери симбол:" Foreground="White" FontSize="14"
                       Margin="0,0,0,10"/>
			<WrapPanel x:Name="symbolPanel" Margin="0,0,0,20"/>

			<TextBlock Text="Твој обид:" Foreground="White" FontSize="14"
                       Margin="0,0,0,10"/>
			<StackPanel x:Name="currentGuess" Orientation="Horizontal"
                        Margin="0,0,0,20" Width="210"/>

			<Button Content="Потврди (Enter)" Height="40" Background="#9AD872"
                    FontSize="14" Click="ConfirmGuess"/>
			<Button Content="Избриши последен (Backspace)" Height="40" Background="#FFA02E"
                    FontSize="12" Margin="0,10,0,0" Click="RemoveLast"/>
			<Button Content="Избриши сè (Delete)" Height="40" Background="#FFEF91"
                    FontSize="14" Margin="0,10,0,0" Click="ClearGuess"/>

			<TextBlock x:Name="txtScore" Foreground="#9AD872" FontSize="16"
                       Margin="0,20,0,0" HorizontalAlignment="Center"/>
		</StackPanel>
	</Grid>
</Window>